[Unit]
Description=Codex Remote Control
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/personal/remote_control/server
EnvironmentFile=/root/personal/remote_control/server/.env
Environment=PATH=/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/usr/bin/pnpm start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
